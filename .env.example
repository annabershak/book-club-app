# Supabase (Settings -> API в панели Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe (Developers -> API keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Домен сайта после деплоя на Vercel, например https://book-club.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Пароль для страницы /admin
ADMIN_PASSWORD=придумай_надёжный_пароль

# Gmail (для отправки писем с подтверждением записи через SMTP)
# GMAIL_APP_PASSWORD — не обычный пароль от почты, а "пароль приложения"
# (Google Account -> Security -> 2-Step Verification -> App passwords)
GMAIL_USER=твоя_почта@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Ссылка-приглашение в WhatsApp-группу клуба (добавляется в письмо)
WHATSAPP_GROUP_URL=https://chat.whatsapp.com/...
